# Required on Vercel: Project Settings → Environment Variables → MONGODB_URI
# Use the standard (non-SRV) Atlas connection string from MongoDB Atlas → Connect → Drivers.
MONGODB_URI=mongodb://user:password@host1:27017,host2:27017,host3:27017/okcredit_inventory?ssl=true&replicaSet=atlas-xxxxx-shard-0&authSource=admin

# Optional: protects POST /api/cron/fetch-rates on Vercel Cron
CRON_SECRET=
